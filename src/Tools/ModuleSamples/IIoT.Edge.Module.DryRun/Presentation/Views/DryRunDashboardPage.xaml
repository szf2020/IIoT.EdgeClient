<Page x:Class="IIoT.Edge.Module.DryRun.Presentation.Views.DryRunDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="DryRunDashboardPage">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="DryRun Module"
                       FontSize="24"
                       FontWeight="Bold" />
            <TextBlock Margin="0,8,0,0"
                       Text="This page exists only to validate third-module onboarding without touching host-core registration."
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,16,0,0"
                       FontWeight="SemiBold"
                       Text="Module status" />
            <TextBlock Text="{Binding ModuleStatus}" TextWrapping="Wrap" />
            <TextBlock Margin="0,16,0,0"
                       FontWeight="SemiBold"
                       Text="Registration status" />
            <TextBlock Text="{Binding RegistrationStatus}" TextWrapping="Wrap" />
            <Border Margin="0,16,0,0"
                    Padding="12"
                    CornerRadius="8"
                    Background="#FFF5F5F5">
                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </Grid>
</Page>
