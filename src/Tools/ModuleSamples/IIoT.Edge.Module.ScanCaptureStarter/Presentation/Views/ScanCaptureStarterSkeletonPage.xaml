<sharedViews:PageActionShell
    x:Class="IIoT.Edge.Module.ScanCaptureStarter.Presentation.Views.ScanCaptureStarterSkeletonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">
    <sharedViews:PageActionShell.HeaderContent>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <materialDesign:PackIcon Width="18" Height="18" Margin="0,0,8,0" Foreground="#38BDF8" Kind="Cog" />
            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#E4E4E7" Text="Scan-Capture Starter" />
        </StackPanel>
    </sharedViews:PageActionShell.HeaderContent>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="18,16" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="10">
            <StackPanel>
                <TextBlock FontSize="12" Foreground="#94A3B8" Text="Module Id" />
                <TextBlock Margin="0,6,0,0" FontSize="26" FontWeight="Bold" Foreground="#E2E8F0" Text="{Binding ModuleId}" />
                <TextBlock Margin="0,10,0,0" Foreground="#CBD5E1" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Margin="0,16,0,0" Columns="2">
            <Border Margin="0,0,8,8" Padding="16,14" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" Text="Module" />
                    <TextBlock Margin="0,10,0,0" Foreground="#CBD5E1" Text="{Binding ModuleStatus}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Margin="8,0,0,8" Padding="16,14" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" Text="Device Binding" />
                    <TextBlock Margin="0,10,0,0" Foreground="#CBD5E1" Text="{Binding DeviceBindingStatus}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Margin="0,8,8,0" Padding="16,14" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" Text="Runtime" />
                    <TextBlock Margin="0,10,0,0" Foreground="#CBD5E1" Text="{Binding RuntimeBindingStatus}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Margin="8,8,0,0" Padding="16,14" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" Text="Latest Sample" />
                    <TextBlock Margin="0,10,0,0" Foreground="#CBD5E1" Text="{Binding SampleDataSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Margin="0,16,0,0" Padding="18,16" Background="#082F49" BorderBrush="#0EA5E9" BorderThickness="1" CornerRadius="10">
            <StackPanel>
                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#BAE6FD" Text="Cloud Upload" />
                <TextBlock Margin="0,10,0,0" Foreground="#E0F2FE" Text="{Binding CloudUploadStatus}" TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0" Foreground="#E0F2FE" Text="{Binding CloudRetryStatus}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</sharedViews:PageActionShell>
