<Window x:Class="IIoT.Edge.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:avalon="https://github.com/Dirkster99/AvalonDock"
        xmlns:headerVM="clr-namespace:IIoT.Edge.UI.Shared.Widgets.SystemHeader;assembly=IIoT.Edge.UI.Shared"
        xmlns:sysMenuVM="clr-namespace:IIoT.Edge.UI.Shared.Widgets.SysMenu;assembly=IIoT.Edge.UI.Shared"
        xmlns:loginVM="clr-namespace:IIoT.Edge.UI.Shared.Widgets.Login;assembly=IIoT.Edge.UI.Shared"
        xmlns:footerVM="clr-namespace:IIoT.Edge.UI.Shared.Widgets.Footer;assembly=IIoT.Edge.UI.Shared"
        xmlns:shared="clr-namespace:IIoT.Edge.UI.Shared.Widgets;assembly=IIoT.Edge.UI.Shared"
        xmlns:sysLog="clr-namespace:IIoT.Edge.Module.SysLog;assembly=IIoT.Edge.Module.SysLog"
        xmlns:equipment="clr-namespace:IIoT.Edge.Module.Production.Equipment;assembly=IIoT.Edge.Module.Production"
        Title="IIoT Edge Client"
        Height="768" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        Foreground="#EAEAEA">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/IIoT.Edge.UI.Shared;component/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="#121212" CornerRadius="8"
            materialDesign:ElevationAssist.Elevation="Dp8">

        <materialDesign:DialogHost Identifier="RootDialog"
                                   DialogTheme="Dark"
                                   CloseOnClickAway="True">
            <materialDesign:DialogHost.DialogContent>
                <loginVM:LoginView DataContext="{Binding LoginViewModel}" />
            </materialDesign:DialogHost.DialogContent>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="45" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>

                <!-- ① 左侧导航栏（跨三行） -->
                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        Background="#18181B"
                        BorderBrush="#27272A"
                        BorderThickness="0,0,1,0"
                        CornerRadius="8,0,0,8">
                    <sysMenuVM:SysMenuView DataContext="{Binding SysMenuViewModel}" />
                </Border>

                <!-- ② 头部 -->
                <ContentControl Grid.Row="0" Grid.Column="1"
                                Content="{Binding HeaderViewModel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <headerVM:HeaderView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- ③ 主工作区：AvalonDock -->
                <avalon:DockingManager Grid.Row="1" Grid.Column="1"
                                       Background="#121212"
                                       BorderThickness="0">
                    <avalon:LayoutRoot>
                        <avalon:LayoutPanel Orientation="Horizontal">

                            <!-- 主内容区 -->
                            <avalon:LayoutDocumentPane>
                                <avalon:LayoutDocument Title="主工作区"
                                                       CanClose="False"
                                                       CanFloat="False">
                                    <Border Background="#1E1E1E" Margin="-2">
                                        <ContentControl Content="{Binding CurrentView}">
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate>
                                                    <shared:PlaceholderView />
                                                </DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>
                                    </Border>
                                </avalon:LayoutDocument>
                            </avalon:LayoutDocumentPane>

                            <!-- 右侧常驻面板 -->
                            <avalon:LayoutAnchorablePaneGroup Orientation="Vertical"
                                                              DockWidth="320">
                                <!-- 设备信息面板 -->
                                <avalon:LayoutAnchorablePane>
                                    <avalon:LayoutAnchorable Title="设备信息"
                                                             CanClose="False"
                                                             CanHide="False"
                                                             CanAutoHide="False"
                                                             CanFloat="False">
                                        <equipment:EquipmentView DataContext="{Binding EquipmentViewModel}" />
                                    </avalon:LayoutAnchorable>
                                </avalon:LayoutAnchorablePane>

                                <!-- 日志面板 -->
                                <avalon:LayoutAnchorablePane>
                                    <avalon:LayoutAnchorable Title="系统日志"
                                                             CanClose="False"
                                                             CanHide="False"
                                                             CanAutoHide="False"
                                                             CanFloat="False">
                                        <sysLog:LogView DataContext="{Binding LogViewModel}" />
                                    </avalon:LayoutAnchorable>
                                </avalon:LayoutAnchorablePane>
                            </avalon:LayoutAnchorablePaneGroup>

                        </avalon:LayoutPanel>
                    </avalon:LayoutRoot>
                </avalon:DockingManager>

                <!-- ④ Footer -->
                <ContentControl Grid.Row="2" Grid.Column="1"
                                Content="{Binding FooterViewModel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <footerVM:FooterView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

            </Grid>
        </materialDesign:DialogHost>
    </Border>
</Window>