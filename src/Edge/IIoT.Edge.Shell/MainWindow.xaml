<Window
    x:Class="IIoT.Edge.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dock="https://github.com/Dirkster99/AvalonDock"
    xmlns:layouts="clr-namespace:IIoT.Edge.UI.Shared.Layouts;assembly=IIoT.Edge.UI.Shared"
    Title="IIoT Edge Controller"
    Width="1200"
    Height="800"
    AllowsTransparency="False"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Border
        Background="White"
        BorderBrush="#E2E8F0"
        BorderThickness="1">
        <Grid>
            <Border
                Height="60"
                VerticalAlignment="Top"
                Panel.ZIndex="1"
                Background="Transparent"
                MouseDown="Border_MouseDown" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <layouts:HeaderView Grid.Row="0" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Background="#F1F5F9"
                        BorderBrush="#E2E8F0"
                        BorderThickness="0,0,1,0">
                        <ListBox
                            x:Name="MenuListBox"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding Menus}"
                            SelectedItem="{Binding SelectedMenu}" />
                    </Border>

                    <dock:DockingManager
                        Grid.Column="1"
                        AnchorablesSource="{Binding Anchorables}"
                        DocumentsSource="{Binding Documents}">
                        <dock:LayoutRoot>
                            <dock:LayoutPanel Orientation="Horizontal">
                                <dock:LayoutDocumentPane />
                            </dock:LayoutPanel>
                        </dock:LayoutRoot>
                    </dock:DockingManager>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>