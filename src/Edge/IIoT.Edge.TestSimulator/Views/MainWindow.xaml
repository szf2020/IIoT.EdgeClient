<Window
    x:Class="IIoT.Edge.TestSimulator.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:IIoT.Edge.TestSimulator.Views"
    Title="IIoT Edge 集成测试模拟器"
    Width="1120"
    Height="800"
    Background="#F5F5F5"
    FontFamily="Microsoft YaHei UI"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <views:InvertBoolConverter x:Key="InvertBool" />

        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter
                                Margin="12,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部导航栏  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="16,10"
            Background="#1565C0"
            CornerRadius="4">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="IIoT Edge 集成测试模拟器" />
                    <TextBlock
                        Margin="0,3,0,0"
                        FontSize="11"
                        Foreground="#BBDEFB"
                        Text="可勾选场景执行：在线上报 / 离线落库 / 恢复补传 / 历史数据生成" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Width="100"
                            Margin="0,0,8,0"
                            Background="#43A047"
                            Command="{Binding RunAllCommand}"
                            Content="▶  运行全部"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Style="{StaticResource RoundBtn}" />
                        <Button
                            Width="100"
                            Margin="0,0,8,0"
                            Background="#2E7D32"
                            Command="{Binding RunSelectedCommand}"
                            Content="▶  运行选中"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Style="{StaticResource RoundBtn}" />
                        <Button
                            Width="120"
                            Margin="0,0,8,0"
                            Background="#EF6C00"
                            Command="{Binding RunOfflineOnlyCommand}"
                            Content="⬇ 仅离线落库"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Style="{StaticResource RoundBtn}" />
                        <!--  历史数据生成专属按钮  -->
                        <Button
                            Width="130"
                            Margin="0,0,8,0"
                            Background="#6A1B9A"
                            Command="{Binding RunHistoricalCommand}"
                            Content="📅 生成历史数据"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Style="{StaticResource RoundBtn}" />
                        <Button
                            Width="90"
                            Background="#757575"
                            Command="{Binding ResetCommand}"
                            Content="↺  重置"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Style="{StaticResource RoundBtn}" />
                    </StackPanel>

                    <CheckBox
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Content="运行前清空 SQLite（建议勾选）"
                        Foreground="White"
                        IsChecked="{Binding ResetBeforeRun}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  主体：左侧日志 + 右侧场景  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="370" />
            </Grid.ColumnDefinitions>

            <!--  日志输出面板  -->
            <Border
                Grid.Column="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Padding="10,7"
                        Background="#ECEFF1"
                        CornerRadius="4,4,0,0">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="#37474F"
                            Text="📋  日志输出" />
                    </Border>

                    <ListBox
                        x:Name="LogListBox"
                        Grid.Row="1"
                        Padding="6,4"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="12"
                        ItemsSource="{Binding LogMessages}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="2,1" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Foreground="#263238"
                                    Text="{Binding}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!--  右侧场景区  -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  场景勾选  -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="12"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontWeight="SemiBold"
                            Foreground="#37474F"
                            Text="🧪 场景选择" />
                        <ItemsControl ItemsSource="{Binding ScenarioSelections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox
                                        Margin="0,2"
                                        Content="{Binding Name}"
                                        IsChecked="{Binding IsSelected}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="11"
                            Foreground="#9E9E9E"
                            Text="💡 历史数据生成请点击顶部紫色按钮单独运行"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  场景结果卡片  -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ScenarioCards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="14,12"
                                    Background="White"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Foreground="#263238"
                                                Text="{Binding Name}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                FontSize="20"
                                                Text="{Binding StatusIcon}" />
                                        </Grid>
                                        <Separator Margin="0,0,0,8" />
                                        <ItemsControl ItemsSource="{Binding AssertionLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock
                                                        Margin="0,2"
                                                        FontFamily="Consolas"
                                                        FontSize="11.5"
                                                        Foreground="#455A64"
                                                        Text="{Binding}"
                                                        TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>