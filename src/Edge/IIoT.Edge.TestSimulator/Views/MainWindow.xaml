<Window x:Class="IIoT.Edge.TestSimulator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:IIoT.Edge.TestSimulator.Views"
        Title="IIoT Edge 集成测试模拟器"
        Width="1120" Height="800"
        Background="#F5F5F5"
        FontFamily="Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <views:InvertBoolConverter x:Key="InvertBool" />

        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="FontWeight"      Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Height"          Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="12,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ── 顶部导航栏 ───────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#1565C0" CornerRadius="4"
                Padding="16,10" Margin="0,0,0,10">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="IIoT Edge 集成测试模拟器"
                               Foreground="White" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="可勾选场景执行：在线上报 / 离线落库 / 恢复补传"
                               Foreground="#BBDEFB" FontSize="11" Margin="0,3,0,0" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="▶  运行全部"
                                Command="{Binding RunAllCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                                Width="100" Background="#43A047"
                                Style="{StaticResource RoundBtn}"
                                Margin="0,0,8,0" />
                        <Button Content="▶  运行选中"
                                Command="{Binding RunSelectedCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                                Width="100" Background="#2E7D32"
                                Style="{StaticResource RoundBtn}"
                                Margin="0,0,8,0" />
                        <Button Content="⬇ 仅离线落库"
                                Command="{Binding RunOfflineOnlyCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                                Width="120" Background="#EF6C00"
                                Style="{StaticResource RoundBtn}"
                                Margin="0,0,8,0" />
                        <Button Content="↺  重置"
                                Command="{Binding ResetCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                                Width="90" Background="#757575"
                                Style="{StaticResource RoundBtn}" />
                    </StackPanel>

                    <CheckBox Content="运行前清空 SQLite（建议勾选）"
                              IsChecked="{Binding ResetBeforeRun}"
                              IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                              Foreground="White"
                              Margin="0,8,0,0"
                              HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 主体：左侧日志 + 右侧场景选择/结果 ───────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"   />
                <ColumnDefinition Width="10"  />
                <ColumnDefinition Width="370" />
            </Grid.ColumnDefinitions>

            <!-- 日志输出面板 -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*"    />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#ECEFF1"
                            Padding="10,7" CornerRadius="4,4,0,0">
                        <TextBlock Text="📋  日志输出"
                                   FontWeight="SemiBold" Foreground="#37474F" />
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="LogListBox"
                             ItemsSource="{Binding LogMessages}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             BorderThickness="0" Background="Transparent"
                             FontFamily="Consolas" FontSize="12" Padding="6,4">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"        Value="2,1" />
                                <Setter Property="Background"     Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#263238" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🧪 场景选择" FontWeight="SemiBold" Foreground="#37474F" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ScenarioSelections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 场景结果卡片 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ScenarioCards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#E0E0E0" BorderThickness="1"
                                        CornerRadius="6" Margin="0,0,0,10" Padding="14,12">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold" FontSize="13"
                                                       Foreground="#263238"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding StatusIcon}"
                                                       HorizontalAlignment="Right"
                                                       FontSize="20" VerticalAlignment="Center" />
                                        </Grid>
                                        <Separator Margin="0,0,0,8" />
                                        <ItemsControl ItemsSource="{Binding AssertionLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               FontFamily="Consolas" FontSize="11.5"
                                                               Foreground="#455A64"
                                                               TextWrapping="Wrap" Margin="0,2" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
