<!--  路径：src/Modules/IIoT.Edge.Module.Production/Equipment/EquipmentView.xaml  -->
<UserControl
    x:Class="IIoT.Edge.Module.Production.Equipment.EquipmentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">

    <Grid>
        <TabControl
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            SelectedIndex="{Binding SelectedTabIndex}">

            <!--  Tab1：硬件状态  -->
            <TabItem Header="硬件状态">
                <DataGrid
                    AlternatingRowBackground="#252525"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserReorderColumns="False"
                    CanUserResizeRows="False"
                    FontSize="12"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#27272A"
                    IsReadOnly="True"
                    ItemsSource="{Binding HardwareItems}"
                    RowBackground="#1E1E1E">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#18181B" />
                            <Setter Property="Foreground" Value="#71717A" />
                            <Setter Property="FontSize" Value="11" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="BorderBrush" Value="#27272A" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="#A1A1AA" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <!--  状态指示灯  -->
                        <DataGridTemplateColumn Width="50" Header="状态">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse
                                        Width="10"
                                        Height="10"
                                        HorizontalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding StatusColor}" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  连接文字  -->
                        <DataGridTemplateColumn Width="60" Header="连接">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Text="{Binding StatusText}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#F44336" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  名称  -->
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Name}"
                            Header="名称" />

                        <!--  地址  -->
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding Address}"
                            Header="地址/端口" />

                        <!--  类型  -->
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding DeviceType}"
                            Header="类型" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!--  Tab2：配方信息  -->
            <TabItem Header="配方信息">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  配方基本信息  -->
                    <Border
                        Grid.Row="0"
                        Padding="8,6"
                        Background="#18181B"
                        BorderBrush="#27272A"
                        BorderThickness="0,0,0,1">
                        <WrapPanel>
                            <TextBlock
                                Margin="0,0,4,0"
                                FontSize="11"
                                Foreground="#71717A">
                                配方：
                            </TextBlock>
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="11"
                                Foreground="#E4E4E7"
                                Text="{Binding RecipeName}" />
                            <TextBlock
                                Margin="0,0,4,0"
                                FontSize="11"
                                Foreground="#71717A">
                                版本：
                            </TextBlock>
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="11"
                                Foreground="#E4E4E7"
                                Text="{Binding RecipeVersion}" />
                            <TextBlock
                                Margin="0,0,4,0"
                                FontSize="11"
                                Foreground="#71717A">
                                工序：
                            </TextBlock>
                            <TextBlock
                                Margin="0,0,12,0"
                                FontSize="11"
                                Foreground="#E4E4E7"
                                Text="{Binding ProcessName}" />
                            <TextBlock
                                Margin="0,0,4,0"
                                FontSize="11"
                                Foreground="#71717A">
                                状态：
                            </TextBlock>
                            <TextBlock Margin="0,0,0,0" FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="未激活" />
                                        <Setter Property="Foreground" Value="#F44336" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRecipeActive}" Value="True">
                                                <Setter Property="Text" Value="✅ 已激活" />
                                                <Setter Property="Foreground" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </WrapPanel>
                    </Border>

                    <!--  参数表格  -->
                    <DataGrid
                        Grid.Row="1"
                        AlternatingRowBackground="#252525"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        CanUserReorderColumns="False"
                        CanUserResizeRows="False"
                        FontSize="12"
                        GridLinesVisibility="Horizontal"
                        HorizontalGridLinesBrush="#27272A"
                        IsReadOnly="True"
                        ItemsSource="{Binding Parameters}"
                        RowBackground="#1E1E1E">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#18181B" />
                                <Setter Property="Foreground" Value="#71717A" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="BorderBrush" Value="#27272A" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="#A1A1AA" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding ParamName}"
                                Header="参数名" />
                            <DataGridTextColumn
                                Width="70"
                                Binding="{Binding CurrentValue}"
                                Header="当前值" />
                            <DataGridTextColumn
                                Width="70"
                                Binding="{Binding MinValue}"
                                Header="最小值" />
                            <DataGridTextColumn
                                Width="70"
                                Binding="{Binding MaxValue}"
                                Header="最大值" />
                            <DataGridTextColumn
                                Width="50"
                                Binding="{Binding Unit}"
                                Header="单位" />
                            <DataGridTextColumn
                                Width="70"
                                Binding="{Binding WarnLow}"
                                Header="预警下限" />
                            <DataGridTextColumn
                                Width="70"
                                Binding="{Binding WarnHigh}"
                                Header="预警上限" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!--  Tab3：实时数据  -->
            <TabItem Header="实时数据">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  统计卡片  -->
                    <UniformGrid
                        Grid.Row="0"
                        Margin="0,8,0,8"
                        Columns="3"
                        Rows="1">
                        <!--  今日产量  -->
                        <Border
                            Margin="4"
                            Padding="12,8"
                            Background="#18181B"
                            CornerRadius="6">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#71717A"
                                    Text="今日产量" />
                                <StackPanel
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Foreground="#E4E4E7"
                                        Text="{Binding TodayOutput}" />
                                    <TextBlock
                                        Margin="2,0,0,3"
                                        VerticalAlignment="Bottom"
                                        FontSize="11"
                                        Foreground="#71717A"
                                        Text=" 片" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  今日良率  -->
                        <Border
                            Margin="4"
                            Padding="12,8"
                            Background="#18181B"
                            CornerRadius="6">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#71717A"
                                    Text="今日良率" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="22"
                                    FontWeight="Bold"
                                    Foreground="#4CAF50"
                                    Text="{Binding TodayYield}" />
                            </StackPanel>
                        </Border>

                        <!--  NG数量  -->
                        <Border
                            Margin="4"
                            Padding="12,8"
                            Background="#18181B"
                            CornerRadius="6">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#71717A"
                                    Text="NG数量" />
                                <StackPanel
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Foreground="#F44336"
                                        Text="{Binding NgCount}" />
                                    <TextBlock
                                        Margin="2,0,0,3"
                                        VerticalAlignment="Bottom"
                                        FontSize="11"
                                        Foreground="#71717A"
                                        Text=" 片" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!--  当前批次  -->
                    <Border
                        Grid.Row="1"
                        Margin="4,0,4,4"
                        Padding="12,8"
                        Background="#18181B"
                        CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="#71717A"
                                Text="当前批次：" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="#E4E4E7"
                                Text="{Binding CurrentBatch}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>