<!--  路径：src/Modules/IIoT.Edge.Module.Production/CapacityView/CapacityViewPage.xaml  -->
<UserControl
    x:Class="IIoT.Edge.Module.Production.CapacityView.CapacityViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部：标题 + 设备选择 + 日期筛选 + 操作  -->
        <Border Grid.Row="0" Padding="16,12">
            <Grid>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,24,0"
                        FontSize="16"
                        FontWeight="Medium"
                        Foreground="#E4E4E7"
                        Text="产能查询" />

                    <!--  设备选择（新增）  -->
                    <TextBlock
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#A1A1AA"
                        Text="设备：" />
                    <ComboBox
                        Width="140"
                        Margin="0,0,16,0"
                        FontSize="12"
                        ItemsSource="{Binding DeviceNames}"
                        SelectedItem="{Binding SelectedDeviceName}" />

                    <!--  日期范围  -->
                    <DatePicker
                        Width="130"
                        Margin="0,0,8,0"
                        FontSize="12"
                        SelectedDate="{Binding DateFrom}" />
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="#A1A1AA"
                        Text="至" />
                    <DatePicker
                        Width="130"
                        Margin="0,0,12,0"
                        FontSize="12"
                        SelectedDate="{Binding DateTo}" />
                    <Button
                        Height="30"
                        Padding="12,0"
                        BorderBrush="#555"
                        Command="{Binding QueryCommand}"
                        Content="查询"
                        FontSize="12"
                        Foreground="#E4E4E7"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>
                <Button
                    Height="32"
                    Padding="16,0"
                    HorizontalAlignment="Right"
                    Background="#0F766E"
                    BorderThickness="0"
                    Command="{Binding ExportCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="16"
                            Height="16"
                            Foreground="White"
                            Kind="FileExcel" />
                        <TextBlock
                            Margin="6,0,0,0"
                            FontSize="13"
                            Foreground="White"
                            Text="导出Excel" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  汇总卡片  -->
        <UniformGrid
            Grid.Row="1"
            Margin="16,0,16,12"
            Columns="5">
            <Border
                Margin="0,0,8,0"
                Padding="16,12"
                Background="#1E1E1E"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="#A1A1AA"
                        Text="区间总产量" />
                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="#E4E4E7"
                        Text="{Binding PeriodTotal}" />
                </StackPanel>
            </Border>
            <Border
                Margin="4,0"
                Padding="16,12"
                Background="#1E1E1E"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="#A1A1AA"
                        Text="良品数" />
                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="#22C55E"
                        Text="{Binding PeriodOk}" />
                </StackPanel>
            </Border>
            <Border
                Margin="4,0"
                Padding="16,12"
                Background="#1E1E1E"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="#A1A1AA"
                        Text="不良数" />
                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="#EF4444"
                        Text="{Binding PeriodNg}" />
                </StackPanel>
            </Border>
            <Border
                Margin="4,0"
                Padding="16,12"
                Background="#1E1E1E"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="#A1A1AA"
                        Text="综合良率" />
                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="#F59E0B"
                        Text="{Binding PeriodYield}" />
                </StackPanel>
            </Border>
            <Border
                Margin="8,0,0,0"
                Padding="16,12"
                Background="#1E1E1E"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="#A1A1AA"
                        Text="日均产量" />
                    <TextBlock
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="#818CF8"
                        Text="{Binding AvgDaily}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!--  每日明细表格  -->
        <Border
            Grid.Row="2"
            Margin="16,0,16,16"
            Background="#1E1E1E"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="8">
            <DataGrid
                AlternatingRowBackground="#232326"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserAddRows="False"
                Foreground="#E4E4E7"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#333"
                IsReadOnly="True"
                ItemsSource="{Binding DailyRecords}"
                RowBackground="#1E1E1E">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding DateFull}"
                        Header="日期" />
                    <DataGridTextColumn
                        Width="60"
                        Binding="{Binding DayOfWeek}"
                        Header="星期" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding Total}"
                        Header="总产量">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding OkCount}"
                        Header="良品">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#22C55E" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding NgCount}"
                        Header="不良">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#EF4444" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="70"
                        Binding="{Binding Yield}"
                        Header="良率">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#F59E0B" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!--  班次明细列（新增）  -->
                    <DataGridTextColumn
                        Width="70"
                        Binding="{Binding DayShiftTotal}"
                        Header="白班">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#F59E0B" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="70"
                        Binding="{Binding DayShiftOk}"
                        Header="白班OK">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#22C55E" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="70"
                        Binding="{Binding DayShiftNg}"
                        Header="白班NG">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#EF4444" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="70"
                        Binding="{Binding NightShiftTotal}"
                        Header="夜班">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#818CF8" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="70"
                        Binding="{Binding NightShiftOk}"
                        Header="夜班OK">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#22C55E" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding NightShiftNg}"
                        Header="夜班NG">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#EF4444" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>