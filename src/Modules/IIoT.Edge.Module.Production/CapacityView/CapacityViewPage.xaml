<!--  路径：src/Modules/IIoT.Edge.Module.Production/CapacityView/CapacityViewPage.xaml  -->
<UserControl
    x:Class="IIoT.Edge.Module.Production.CapacityView.CapacityViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="280" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16,12">
            <Grid>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,24,0"
                        FontSize="16"
                        FontWeight="Medium"
                        Foreground="#E4E4E7"
                        Text="产能查询" />

                    <TextBlock
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#A1A1AA"
                        Text="设备：" />
                    <ComboBox
                        Width="150"
                        Margin="0,0,12,0"
                        FontSize="12"
                        ItemsSource="{Binding DeviceNames}"
                        SelectedItem="{Binding SelectedDeviceName}" />

                    <ComboBox
                        Width="120"
                        Margin="0,0,12,0"
                        FontSize="12"
                        ItemsSource="{Binding QueryModes}"
                        SelectedItem="{Binding SelectedQueryMode}" />

                    <DatePicker
                        Width="130"
                        Margin="0,0,12,0"
                        FontSize="12"
                        SelectedDate="{Binding QueryDate}" />

                    <Button
                        Height="30"
                        Padding="12,0"
                        BorderBrush="#555"
                        Command="{Binding QueryCommand}"
                        Content="查询"
                        FontSize="12"
                        Foreground="#E4E4E7"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Visibility="{Binding CanQueryCloud, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="#F59E0B"
                        Text="{Binding OfflineHint}" />
                </StackPanel>

                <Button
                    Height="32"
                    Padding="16,0"
                    HorizontalAlignment="Right"
                    Background="#0F766E"
                    BorderThickness="0"
                    Command="{Binding ExportCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="16"
                            Height="16"
                            Foreground="White"
                            Kind="FileExcel" />
                        <TextBlock
                            Margin="6,0,0,0"
                            FontSize="13"
                            Foreground="White"
                            Text="导出Excel" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <UniformGrid
            Grid.Row="1"
            Margin="16,0,16,12"
            Columns="5">
            <Border Margin="0,0,8,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="#A1A1AA" Text="总产量" />
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="#E4E4E7" Text="{Binding PeriodTotal}" />
                </StackPanel>
            </Border>
            <Border Margin="4,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="#A1A1AA" Text="良品" />
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="#22C55E" Text="{Binding PeriodOk}" />
                </StackPanel>
            </Border>
            <Border Margin="4,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="#A1A1AA" Text="不良" />
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="#EF4444" Text="{Binding PeriodNg}" />
                </StackPanel>
            </Border>
            <Border Margin="4,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="#A1A1AA" Text="良率" />
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="#F59E0B" Text="{Binding PeriodYield}" />
                </StackPanel>
            </Border>
            <Border Margin="8,0,0,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="12" Foreground="#A1A1AA" Text="均值" />
                    <TextBlock FontSize="26" FontWeight="Bold" Foreground="#818CF8" Text="{Binding AvgDaily}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border
            Grid.Row="2"
            Margin="16,0,16,12"
            Background="#1E1E1E"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="8">
            <DataGrid
                AlternatingRowBackground="#232326"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserAddRows="False"
                Foreground="#E4E4E7"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#333"
                IsReadOnly="True"
                ItemsSource="{Binding DailyRecords}"
                RowBackground="#1E1E1E">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="120" Binding="{Binding DateFull}" Header="时间/日期" />
                    <DataGridTextColumn Width="80" Binding="{Binding DayOfWeek}" Header="班次" />
                    <DataGridTextColumn Width="80" Binding="{Binding Total}" Header="产能总数" />
                    <DataGridTextColumn Width="80" Binding="{Binding OkCount}" Header="OK总数" />
                    <DataGridTextColumn Width="80" Binding="{Binding NgCount}" Header="NG总数" />
                    <DataGridTextColumn Width="80" Binding="{Binding Yield}" Header="良率" />
                    <DataGridTextColumn Width="80" Binding="{Binding DayShiftTotal}" Header="白班" />
                    <DataGridTextColumn Width="80" Binding="{Binding NightShiftTotal}" Header="夜班" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border
            Grid.Row="3"
            Margin="16,0,16,16"
            Background="#1E1E1E"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="8">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0" ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" VerticalAlignment="Bottom" Height="190">
                                    <Border
                                        VerticalAlignment="Bottom"
                                        Height="{Binding ChartHeight}"
                                        Background="#6366F1"
                                        CornerRadius="4,4,0,0" />
                                </Grid>
                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#A1A1AA"
                                    Text="{Binding Label}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding ChartBars}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="#E4E4E7"
                                Text="{Binding Value}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>