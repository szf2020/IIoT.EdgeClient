<!--  路径：src/Modules/IIoT.Edge.Module.Production/Monitor/MonitorViewPage.xaml  -->
<UserControl
    x:Class="IIoT.Edge.Module.Production.Monitor.MonitorViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  标题  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="18"
            FontWeight="Bold"
            Foreground="#E4E4E7"
            Text="实时数据监控" />

        <!--  PLC设备Tab  -->
        <TabControl
            Grid.Row="1"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding DeviceTabs}"
            SelectedIndex="{Binding SelectedTabIndex}">

            <!--  Tab页签样式：显示设备名称  -->
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock
                        Padding="12,6"
                        FontSize="13"
                        Text="{Binding DeviceName}" />
                </DataTemplate>
            </TabControl.ItemTemplate>

            <!--  Tab内容  -->
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  状态机  -->
                        <Border
                            Grid.Row="0"
                            Margin="0,8,0,4"
                            Padding="10,6"
                            Background="#18181B"
                            CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#71717A"
                                    Text="状态机：" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#A1A1AA"
                                    Text="{Binding StepSummary}" />
                            </StackPanel>
                        </Border>

                        <!--  设备数据  -->
                        <Border
                            Grid.Row="1"
                            Margin="0,0,0,4"
                            Padding="10,6"
                            Background="#18181B"
                            CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#71717A"
                                    Text="设备数据：" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#A1A1AA"
                                    Text="{Binding DeviceDataSummary}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!--  电芯数量  -->
                        <TextBlock
                            Grid.Row="2"
                            Margin="0,4,0,4"
                            FontSize="12"
                            Foreground="#71717A">
                            <Run Text="在制电芯：" />
                            <Run Text="{Binding CellCount, Mode=OneWay}" />
                            <Run Text=" 个" />
                        </TextBlock>

                        <!--  电芯数据表格（DataGrid绑定DataTable，列自动生成）  -->
                        <DataGrid
                            Grid.Row="3"
                            AlternatingRowBackground="#252525"
                            AutoGenerateColumns="True"
                            Background="Transparent"
                            BorderThickness="0"
                            CanUserReorderColumns="False"
                            CanUserResizeRows="False"
                            FontSize="12"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column"
                            HorizontalGridLinesBrush="#27272A"
                            IsReadOnly="True"
                            ItemsSource="{Binding CellTable}"
                            RowBackground="#1E1E1E">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#18181B" />
                                    <Setter Property="Foreground" Value="#71717A" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="BorderBrush" Value="#27272A" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#A1A1AA" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.CellStyle>
                        </DataGrid>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>