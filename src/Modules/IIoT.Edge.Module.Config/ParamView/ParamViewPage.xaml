<UserControl
    x:Class="IIoT.Edge.Module.Config.ParamView.ParamViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:IIoT.Edge.Module.Config.ParamView"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16,12">
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="#E4E4E7"
                    Text="参数配置" />
                <Button
                    Height="32"
                    Padding="16,0"
                    HorizontalAlignment="Right"
                    Background="#0F766E"
                    BorderThickness="0"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="16"
                            Height="16"
                            Foreground="White"
                            Kind="ContentSave" />
                        <TextBlock
                            Margin="6,0,0,0"
                            FontSize="13"
                            Foreground="White"
                            Text="保存" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <TabControl
            Grid.Row="1"
            Padding="0"
            Background="Transparent"
            BorderThickness="0"
            SelectedIndex="{Binding SelectedTabIndex}">

            <!--  ══════ Tab1: 通用参数 ══════  -->
            <TabItem Header="通用参数">
                <Border
                    Margin="16"
                    Background="#1E1E1E"
                    BorderBrush="#333"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Padding="12,0"
                            Background="#27272A"
                            CornerRadius="8,8,0,0">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <Button
                                    Height="28"
                                    Margin="0,0,8,0"
                                    Padding="12,0"
                                    BorderBrush="#22C55E"
                                    Command="{Binding DataContext.AddGeneralParamCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="新增参数"
                                    FontSize="12"
                                    Foreground="#22C55E"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                                <Button
                                    Height="28"
                                    Padding="12,0"
                                    BorderBrush="#EF4444"
                                    Command="{Binding DataContext.DeleteGeneralParamCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding SelectedItem, ElementName=GeneralParamGrid}"
                                    Content="删除选中"
                                    FontSize="12"
                                    Foreground="#EF4444"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                            </StackPanel>
                        </Border>

                        <DataGrid
                            x:Name="GeneralParamGrid"
                            Grid.Row="1"
                            AlternatingRowBackground="#232326"
                            AutoGenerateColumns="False"
                            Background="Transparent"
                            BorderThickness="0"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserSortColumns="False"
                            Foreground="#E4E4E7"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column"
                            HorizontalGridLinesBrush="#333"
                            ItemsSource="{Binding GeneralParams}"
                            RowBackground="#1E1E1E"
                            RowHeight="42">
                            <DataGrid.Columns>
                                <DataGridComboBoxColumn
                                    Width="200"
                                    Header="参数名称"
                                    ItemsSource="{Binding Source={x:Static local:ParamViewHelper.SystemConfigKeyNames}}"
                                    SelectedItemBinding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Header="参数值">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="Padding" Value="12,0" />
                                            <Setter Property="Foreground" Value="#E4E4E7" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!--  ══════ Tab2: 设备参数 ══════  -->
            <TabItem Header="设备参数">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Background="#1E1E1E"
                        BorderBrush="#333"
                        BorderThickness="1"
                        CornerRadius="8">
                        <ListBox
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#E4E4E7"
                            ItemsSource="{Binding DeviceParamGroups}"
                            SelectedItem="{Binding SelectedGroup}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Padding="8,10"
                                        FontSize="13"
                                        Text="{Binding DeviceName}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Background="#1E1E1E"
                        BorderBrush="#333"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border
                                Grid.Row="0"
                                Padding="12,0"
                                Background="#27272A"
                                CornerRadius="8,8,0,0">
                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                    <Button
                                        Height="28"
                                        Margin="0,0,8,0"
                                        Padding="12,0"
                                        BorderBrush="#22C55E"
                                        Command="{Binding DataContext.AddDeviceParamCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Content="新增参数"
                                        FontSize="12"
                                        Foreground="#22C55E"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    <Button
                                        Height="28"
                                        Padding="12,0"
                                        BorderBrush="#EF4444"
                                        Command="{Binding DataContext.DeleteDeviceParamCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding SelectedItem, ElementName=DeviceParamGrid}"
                                        Content="删除选中"
                                        FontSize="12"
                                        Foreground="#EF4444"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                </StackPanel>
                            </Border>

                            <DataGrid
                                x:Name="DeviceParamGrid"
                                Grid.Row="1"
                                AlternatingRowBackground="#232326"
                                AutoGenerateColumns="False"
                                Background="Transparent"
                                BorderThickness="0"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                Foreground="#E4E4E7"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                HorizontalGridLinesBrush="#333"
                                ItemsSource="{Binding SelectedGroup.Params}"
                                RowBackground="#1E1E1E">
                                <DataGrid.Columns>
                                    <DataGridComboBoxColumn
                                        Width="150"
                                        Header="参数名称"
                                        ItemsSource="{Binding Source={x:Static local:ParamViewHelper.DeviceParamKeyNames}}"
                                        SelectedItemBinding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Header="当前值">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#22C55E" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn
                                        Width="60"
                                        Binding="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Header="单位" />
                                    <DataGridTextColumn
                                        Width="70"
                                        Binding="{Binding Min, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Header="最小值" />
                                    <DataGridTextColumn
                                        Width="70"
                                        Binding="{Binding Max, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Header="最大值" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>