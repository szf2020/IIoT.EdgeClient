<UserControl
    x:Class="IIoT.Edge.Module.Formula.RecipeView.RecipeViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16,12">
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="#E4E4E7"
                    Text="产品配方（云端只读）" />
                <Button
                    Height="32"
                    Padding="16,0"
                    HorizontalAlignment="Right"
                    Background="#1E40AF"
                    BorderThickness="0"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="16"
                            Height="16"
                            Foreground="White"
                            Kind="CloudSync" />
                        <TextBlock
                            Margin="6,0,0,0"
                            FontSize="13"
                            Foreground="White"
                            Text="同步云端" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="#1E1E1E"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="8">
                <ListBox
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding Recipes}"
                    SelectedItem="{Binding SelectedRecipe}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12,10"
                                BorderBrush="#333"
                                BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Medium"
                                            Foreground="#E4E4E7"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontSize="12"
                                            Foreground="#71717A"
                                            Text="{Binding Version}" />
                                    </Grid>
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="11"
                                        Foreground="#71717A"
                                        Text="{Binding Process}" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="11"
                                        Text="{Binding Status}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#A1A1AA" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="已启用">
                                                        <Setter Property="Foreground" Value="#22C55E" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="待审核">
                                                        <Setter Property="Foreground" Value="#F59E0B" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="已停用">
                                                        <Setter Property="Foreground" Value="#EF4444" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border
                Grid.Column="2"
                Padding="20,16"
                Background="#1E1E1E"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="8">
                <Grid DataContext="{Binding SelectedRecipe}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#E4E4E7"
                            Text="{Binding Name}" />
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <TextBlock
                                FontSize="12"
                                Foreground="#71717A"
                                Text="版本: " />
                            <TextBlock
                                Margin="0,0,16,0"
                                FontSize="12"
                                Foreground="#A1A1AA"
                                Text="{Binding Version}" />
                            <TextBlock
                                FontSize="12"
                                Foreground="#71717A"
                                Text="工序: " />
                            <TextBlock
                                Margin="0,0,16,0"
                                FontSize="12"
                                Foreground="#A1A1AA"
                                Text="{Binding Process}" />
                            <TextBlock
                                FontSize="12"
                                Foreground="#71717A"
                                Text="更新: " />
                            <TextBlock
                                FontSize="12"
                                Foreground="#A1A1AA"
                                Text="{Binding UpdatedAt}" />
                        </StackPanel>
                    </StackPanel>

                    <DataGrid
                        Grid.Row="2"
                        AlternatingRowBackground="#232326"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        CanUserAddRows="False"
                        Foreground="#E4E4E7"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        HorizontalGridLinesBrush="#333"
                        IsReadOnly="True"
                        ItemsSource="{Binding Params}"
                        RowBackground="#1E1E1E">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Name}"
                                Header="参数名" />
                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding Value}"
                                Header="设定值">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#22C55E" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn
                                Width="80"
                                Binding="{Binding Unit}"
                                Header="单位" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>