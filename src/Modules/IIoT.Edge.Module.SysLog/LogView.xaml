<UserControl
    x:Class="IIoT.Edge.Module.SysLog.LogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  工具栏：低调小按钮  -->
        <Border
            Grid.Row="0"
            Padding="8,4"
            BorderBrush="#27272A"
            BorderThickness="0,0,0,1">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Height="22"
                    Padding="4,0"
                    Command="{Binding ClearCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    ToolTip="清空日志">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="12"
                            Height="12"
                            VerticalAlignment="Center"
                            Foreground="#52525B"
                            Kind="DeleteOutline" />
                        <TextBlock
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="#52525B"
                            Text="清空" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!--  日志列表  -->
        <ListView
            Grid.Row="1"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Entries}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="8,2" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  时间  -->
                        <TextBlock
                            Grid.Column="0"
                            FontSize="11"
                            Foreground="#52525B"
                            Text="{Binding Time, StringFormat='{}{0:MM-dd HH:mm:ss.fff}'}" />

                        <!--  级别  -->
                        <TextBlock
                            Grid.Column="1"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Text="{Binding Level}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#A1A1AA" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                            <Setter Property="Foreground" Value="#F44336" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="FATAL">
                                            <Setter Property="Foreground" Value="#FF1744" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                            <Setter Property="Foreground" Value="#FFC107" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="INFO">
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="DEBUG">
                                            <Setter Property="Foreground" Value="#607D8B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!--  消息  -->
                        <TextBlock
                            Grid.Column="2"
                            FontSize="11"
                            Foreground="#A1A1AA"
                            Text="{Binding Message}"
                            TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>