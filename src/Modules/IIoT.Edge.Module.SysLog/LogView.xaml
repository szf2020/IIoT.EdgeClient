<!--路径：src/Modules/IIoT.Edge.Module.SysLog/LogView.xaml-->
<UserControl x:Class="IIoT.Edge.Module.SysLog.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Margin="8,4,8,4">
            <TextBlock Text="系统日志"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesignBody}" />
            <Button Command="{Binding ClearCommand}"
                    Margin="12,0,0,0"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    ToolTip="清空日志"
                    Height="24" Padding="8,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" />
                    <TextBlock Text="清空" Margin="4,0,0,0" FontSize="12" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- 日志列表 -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 时间 -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Time, StringFormat='{}{0:MM-dd HH:mm:ss.fff}'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />

                        <!-- 级别（颜色区分） -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Level}"
                                   FontSize="11"
                                   FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                            <Setter Property="Foreground" Value="#F44336" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="FATAL">
                                            <Setter Property="Foreground" Value="#FF1744" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                            <Setter Property="Foreground" Value="#FFC107" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="INFO">
                                            <Setter Property="Foreground" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="DEBUG">
                                            <Setter Property="Foreground" Value="#607D8B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 消息 -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Message}"
                                   FontSize="11"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>