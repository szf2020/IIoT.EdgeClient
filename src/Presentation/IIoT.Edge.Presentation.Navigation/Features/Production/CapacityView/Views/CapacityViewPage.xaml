<sharedViews:PageActionShell
    x:Class="IIoT.Edge.Presentation.Navigation.Features.Production.CapacityView.CapacityViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">
    <sharedViews:PageActionShell.HeaderContent>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Medium"
                Foreground="#E4E4E7"
                Text="产能查询" />

            <ComboBox
                Grid.Column="1"
                Width="200"
                Margin="0,0,8,0"
                materialDesign:HintAssist.Hint="选择设备"
                DisplayMemberPath="."
                FontSize="13"
                Foreground="#E4E4E7"
                ItemsSource="{Binding DeviceNames}"
                SelectedItem="{Binding SelectedDeviceName}"
                Style="{StaticResource MaterialDesignOutlinedComboBox}" />

            <ComboBox
                Grid.Column="2"
                Width="130"
                Margin="0,0,8,0"
                materialDesign:HintAssist.Hint="查询维度"
                FontSize="13"
                Foreground="#E4E4E7"
                ItemsSource="{Binding QueryModes}"
                SelectedItem="{Binding SelectedQueryMode}"
                Style="{StaticResource MaterialDesignOutlinedComboBox}" />

            <DatePicker
                Grid.Column="3"
                Margin="0,0,8,0"
                FontSize="12"
                SelectedDate="{Binding QueryDate}" />

            <Button
                Grid.Column="4"
                Height="32"
                Padding="16,0"
                BorderBrush="#555"
                Command="{Binding QueryCommand}"
                Content="查询"
                FontSize="12"
                Foreground="#E4E4E7"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
        </Grid>
    </sharedViews:PageActionShell.HeaderContent>

    <sharedViews:PageActionShell.ActionContent>
        <StackPanel Orientation="Horizontal">
            <Button
                Height="32"
                Padding="16,0"
                Background="#0F766E"
                BorderThickness="0"
                Command="{Binding ExportCommand}"
                Style="{StaticResource MaterialDesignRaisedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="16" Height="16" Foreground="White" Kind="FileExcel" />
                    <TextBlock Margin="6,0,0,0" FontSize="13" Foreground="White" Text="导出 Excel" />
                </StackPanel>
            </Button>
        </StackPanel>
    </sharedViews:PageActionShell.ActionContent>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="12"
            Foreground="#F59E0B"
            Text="{Binding OfflineHint}" />

        <UniformGrid Grid.Row="1" Margin="0,0,0,12" Columns="4">
            <Border Margin="0,0,8,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8"><StackPanel><TextBlock FontSize="12" Foreground="#A1A1AA" Text="产量合计" /><TextBlock FontSize="28" FontWeight="Bold" Foreground="#E4E4E7" Text="{Binding PeriodTotal}" /></StackPanel></Border>
            <Border Margin="4,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8"><StackPanel><TextBlock FontSize="12" Foreground="#A1A1AA" Text="良品" /><TextBlock FontSize="28" FontWeight="Bold" Foreground="#22C55E" Text="{Binding PeriodOk}" /></StackPanel></Border>
            <Border Margin="4,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8"><StackPanel><TextBlock FontSize="12" Foreground="#A1A1AA" Text="不良" /><TextBlock FontSize="28" FontWeight="Bold" Foreground="#EF4444" Text="{Binding PeriodNg}" /></StackPanel></Border>
            <Border Margin="8,0,0,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8"><StackPanel><TextBlock FontSize="12" Foreground="#A1A1AA" Text="平均/日" /><TextBlock FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Text="{Binding AvgDaily}" /></StackPanel></Border>
        </UniformGrid>

        <DataGrid
            Grid.Row="2"
            AutoGenerateColumns="False"
            BorderThickness="0"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            Foreground="#E4E4E7"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="#333"
            IsReadOnly="True"
            ItemsSource="{Binding DailyRecords}"
            RowBackground="#1E1E1E"
            RowHeight="42">
            <DataGrid.Columns>
                <DataGridTextColumn Width="90" Binding="{Binding Date}" Header="日期" />
                <DataGridTextColumn Width="100" Binding="{Binding DayOfWeek}" Header="星期" />
                <DataGridTextColumn Width="90" Binding="{Binding Total}" Header="总量" />
                <DataGridTextColumn Width="90" Binding="{Binding OkCount}" Header="良品" />
                <DataGridTextColumn Width="90" Binding="{Binding NgCount}" Header="不良" />
                <DataGridTextColumn Width="90" Binding="{Binding Yield}" Header="良率" />
                <DataGridTextColumn Width="90" Binding="{Binding DayShiftTotal}" Header="白班" />
                <DataGridTextColumn Width="90" Binding="{Binding NightShiftTotal}" Header="夜班" />
                <DataGridTextColumn Width="100" Binding="{Binding DateFull}" Header="完整日期" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Margin="0,12,0,0" Padding="16" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
            <ItemsControl ItemsSource="{Binding ChartBars}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="{Binding ChartBars.Count}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="24" Margin="2,0">
                            <Border
                                Background="#22C55E"
                                CornerRadius="4,4,0,0"
                                Height="{Binding ChartHeight}"
                                Width="24" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="10"
                                Foreground="#A1A1AA"
                                Text="{Binding Label}"
                                TextAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</sharedViews:PageActionShell>
