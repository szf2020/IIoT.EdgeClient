<sharedViews:PageActionShell
    x:Class="IIoT.Edge.Presentation.Navigation.Features.Production.Monitor.MonitorViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">
    <sharedViews:PageActionShell.HeaderContent>
        <TextBlock FontSize="18"
                   FontWeight="Bold"
                   Foreground="#E4E4E7"
                   Text="Real-time Monitor" />
    </sharedViews:PageActionShell.HeaderContent>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding DeviceTabs}"
                    SelectedIndex="{Binding SelectedTabIndex}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Padding="12,6"
                               FontSize="13"
                               Text="{Binding DeviceName}" />
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <UniformGrid Grid.Row="0"
                                     Margin="0,8,0,8"
                                     Columns="3">
                            <Border Margin="0,0,6,0"
                                    Padding="12,8"
                                    Background="#1E1E1E"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#F59E0B"
                                               Text="Day Shift" />
                                    <StackPanel Margin="0,6,0,0"
                                                Orientation="Horizontal">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="Total" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#E4E4E7"
                                                       Text="{Binding DayShiftTotal}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="OK" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#22C55E"
                                                       Text="{Binding DayShiftOk}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="NG" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#EF4444"
                                                       Text="{Binding DayShiftNg}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="Yield" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#F59E0B"
                                                       Text="{Binding DayShiftYield}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="3,0"
                                    Padding="12,8"
                                    Background="#1E1E1E"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#818CF8"
                                               Text="Night Shift" />
                                    <StackPanel Margin="0,6,0,0"
                                                Orientation="Horizontal">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="Total" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#E4E4E7"
                                                       Text="{Binding NightShiftTotal}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="OK" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#22C55E"
                                                       Text="{Binding NightShiftOk}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="NG" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#EF4444"
                                                       Text="{Binding NightShiftNg}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="Yield" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#818CF8"
                                                       Text="{Binding NightShiftYield}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="6,0,0,0"
                                    Padding="12,8"
                                    Background="#1E1E1E"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#0EA5E9"
                                               Text="Today Total" />
                                    <StackPanel Margin="0,6,0,0"
                                                Orientation="Horizontal">
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="Total" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#E4E4E7"
                                                       Text="{Binding TotalAll}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="OK" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#22C55E"
                                                       Text="{Binding OkAll}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="NG" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#EF4444"
                                                       Text="{Binding NgAll}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock FontSize="10"
                                                       Foreground="#71717A"
                                                       Text="Yield" />
                                            <TextBlock FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#0EA5E9"
                                                       Text="{Binding YieldAll}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="1"
                                Margin="0,0,0,4"
                                Padding="10,6"
                                Background="#18181B"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#71717A"
                                           Text="State Machine: " />
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#A1A1AA"
                                           Text="{Binding StepSummary}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,0,0,4"
                                Padding="10,6"
                                Background="#18181B"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#71717A"
                                           Text="Device Data: " />
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#A1A1AA"
                                           Text="{Binding DeviceDataSummary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="0,0,0,4"
                                Padding="10,6"
                                Background="#18181B"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#71717A"
                                           Text="Cloud Sync: " />
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#A1A1AA"
                                           Text="{Binding CloudSyncStatus}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Margin="0,0,0,4"
                                Padding="10,6"
                                Background="#18181B"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#71717A"
                                           Text="MES Sync: " />
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#A1A1AA"
                                           Text="{Binding MesSyncStatus}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="5"
                                Margin="0,0,0,4"
                                Padding="10,6"
                                Background="#18181B"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Top"
                                           FontSize="11"
                                           Foreground="#71717A"
                                           Text="Context Persistence: " />
                                <TextBlock VerticalAlignment="Top"
                                           FontSize="11"
                                           Foreground="#A1A1AA"
                                           Text="{Binding ContextPersistenceStatus}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="6"
                                   Margin="0,4,0,4"
                                   FontSize="12"
                                   Foreground="#71717A">
                            <Run Text="In-process Cells: " />
                            <Run Text="{Binding CellCount, Mode=OneWay}" />
                            <Run Text=" pcs" />
                        </TextBlock>

                        <DataGrid Grid.Row="7"
                                  AlternatingRowBackground="#252525"
                                  AutoGenerateColumns="True"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  CanUserReorderColumns="False"
                                  CanUserResizeRows="False"
                                  FontSize="12"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  HorizontalGridLinesBrush="#27272A"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding CellTable}"
                                  RowBackground="#1E1E1E">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#18181B" />
                                    <Setter Property="Foreground" Value="#71717A" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="BorderBrush" Value="#27272A" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#A1A1AA" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.CellStyle>
                        </DataGrid>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</sharedViews:PageActionShell>
