<sharedViews:PageActionShell
    x:Class="IIoT.Edge.Presentation.Navigation.Features.Production.DataView.DataViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">
    <sharedViews:PageActionShell.HeaderContent>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Margin="0,0,24,0" FontSize="16" FontWeight="Medium" Foreground="#E4E4E7" Text="生产数据" />
            <DatePicker Width="130" Margin="0,0,8,0" FontSize="12" SelectedDate="{Binding DateFrom}" />
            <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#A1A1AA" Text="至" />
            <DatePicker Width="130" Margin="0,0,12,0" FontSize="12" SelectedDate="{Binding DateTo}" />
            <Button Height="30" Padding="12,0" BorderBrush="#555" Command="{Binding QueryCommand}" Content="查询" FontSize="12" Foreground="#E4E4E7" Style="{StaticResource MaterialDesignOutlinedButton}" />
        </StackPanel>
    </sharedViews:PageActionShell.HeaderContent>
    <sharedViews:PageActionShell.ActionContent>
        <Button Height="32" Padding="16,0" HorizontalAlignment="Right" Background="#0F766E" BorderThickness="0" Command="{Binding ExportCommand}" Style="{StaticResource MaterialDesignRaisedButton}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Width="16" Height="16" Foreground="White" Kind="FileExcel" />
                <TextBlock Margin="6,0,0,0" FontSize="13" Foreground="White" Text="导出 Excel" />
            </StackPanel>
        </Button>
    </sharedViews:PageActionShell.ActionContent>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Margin="16,0,16,12" Columns="4">
            <Border Margin="0,0,8,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8"><StackPanel><TextBlock FontSize="12" Foreground="#A1A1AA" Text="今日产量" /><TextBlock FontSize="28" FontWeight="Bold" Foreground="#E4E4E7" Text="{Binding TodayTotal}" /></StackPanel></Border>
            <Border Margin="4,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8"><StackPanel><TextBlock FontSize="12" Foreground="#A1A1AA" Text="良品数" /><TextBlock FontSize="28" FontWeight="Bold" Foreground="#22C55E" Text="{Binding TodayOk}" /></StackPanel></Border>
            <Border Margin="4,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8"><StackPanel><TextBlock FontSize="12" Foreground="#A1A1AA" Text="不良数" /><TextBlock FontSize="28" FontWeight="Bold" Foreground="#EF4444" Text="{Binding TodayNg}" /></StackPanel></Border>
            <Border Margin="8,0,0,0" Padding="16,12" Background="#1E1E1E" CornerRadius="8"><StackPanel><TextBlock FontSize="12" Foreground="#A1A1AA" Text="良率" /><TextBlock FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Text="{Binding TodayYield}" /></StackPanel></Border>
        </UniformGrid>

        <Border Grid.Row="1" Margin="16,0,16,16" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
            <DataGrid AlternatingRowBackground="#232326" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0" CanUserAddRows="False" Foreground="#E4E4E7" GridLinesVisibility="Horizontal" HeadersVisibility="Column" HorizontalGridLinesBrush="#333" IsReadOnly="True" ItemsSource="{Binding Records}" RowBackground="#1E1E1E">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="80" Binding="{Binding Time}" Header="时间" />
                    <DataGridTextColumn Width="*" Binding="{Binding BatchNo}" Header="批次号" />
                    <DataGridTextColumn Width="70" Binding="{Binding Total}" Header="总数" />
                    <DataGridTextColumn Width="70" Binding="{Binding OkCount}" Header="良品"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#22C55E" /></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                    <DataGridTextColumn Width="70" Binding="{Binding NgCount}" Header="不良"><DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#EF4444" /></Style></DataGridTextColumn.ElementStyle></DataGridTextColumn>
                    <DataGridTextColumn Width="80" Binding="{Binding Yield}" Header="良率" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</sharedViews:PageActionShell>
