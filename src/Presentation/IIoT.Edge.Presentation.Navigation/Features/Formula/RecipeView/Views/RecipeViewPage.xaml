<sharedViews:PageActionShell
    x:Class="IIoT.Edge.Presentation.Navigation.Features.Formula.RecipeView.RecipeViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">

    <sharedViews:PageActionShell.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </sharedViews:PageActionShell.Resources>

    <sharedViews:PageActionShell.HeaderContent>
        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <TextBlock
                Margin="0,0,16,0"
                FontSize="16"
                FontWeight="Medium"
                Foreground="#E4E4E7"
                Text="产品配方" />
            <Border
                Padding="8,3"
                Background="#18181B"
                CornerRadius="4">
                <TextBlock
                    FontSize="12"
                    Foreground="#F59E0B"
                    Text="{Binding SourceLabel}" />
            </Border>
        </StackPanel>
    </sharedViews:PageActionShell.HeaderContent>

    <sharedViews:PageActionShell.ActionContent>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button
                Height="32"
                Margin="0,0,8,0"
                Padding="12,0"
                Background="#7C3AED"
                BorderThickness="0"
                Command="{Binding SwitchSourceCommand}"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Visibility="{Binding IsLocalAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="16" Height="16" Foreground="White" Kind="SwapHorizontal" />
                    <TextBlock Margin="4,0,0,0" FontSize="12" Foreground="White" Text="切换数据源" />
                </StackPanel>
            </Button>
            <Button
                Height="32"
                Padding="12,0"
                Background="#1E40AF"
                BorderThickness="0"
                Command="{Binding SyncCloudCommand}"
                Style="{StaticResource MaterialDesignRaisedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="16" Height="16" Foreground="White" Kind="CloudSync" />
                    <TextBlock Margin="6,0,0,0" FontSize="13" Foreground="White" Text="同步云端" />
                </StackPanel>
            </Button>
        </StackPanel>
    </sharedViews:PageActionShell.ActionContent>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="16,0,16,8"
            Padding="16,10"
            Background="#1E1E1E"
            CornerRadius="6">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="Bold" Foreground="#E4E4E7" Text="{Binding RecipeName}" />
                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                    <TextBlock FontSize="12" Foreground="#71717A" Text="版本: " />
                    <TextBlock Margin="0,0,16,0" FontSize="12" Foreground="#A1A1AA" Text="{Binding RecipeVersion}" />
                    <TextBlock FontSize="12" Foreground="#71717A" Text="工序: " />
                    <TextBlock Margin="0,0,16,0" FontSize="12" Foreground="#A1A1AA" Text="{Binding ProcessName}" />
                    <TextBlock FontSize="12" Foreground="#71717A" Text="更新: " />
                    <TextBlock FontSize="12" Foreground="#A1A1AA" Text="{Binding UpdatedAt}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            Margin="16,0,16,8"
            Background="#1E1E1E"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="8">
            <DataGrid
                AlternatingRowBackground="#232326"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserAddRows="False"
                Foreground="#E4E4E7"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                HorizontalGridLinesBrush="#333"
                IsReadOnly="True"
                ItemsSource="{Binding Params}"
                RowBackground="#1E1E1E">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding Name}" Header="参数名" />
                    <DataGridTextColumn Width="100" Binding="{Binding Min}" Header="下限">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#0EA5E9" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="100" Binding="{Binding Max}" Header="上限">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#EF4444" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="80" Binding="{Binding Unit}" Header="单位" />
                    <DataGridTemplateColumn Width="60" Header="">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    Width="24"
                                    Height="24"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    Command="{Binding DataContext.DeleteLocalParamCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Name}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="删除参数">
                                    <Button.Visibility>
                                        <Binding
                                            Converter="{StaticResource BooleanToVisibilityConverter}"
                                            Path="DataContext.IsLocalAdmin"
                                            RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </Button.Visibility>
                                    <materialDesign:PackIcon Width="14" Height="14" Foreground="#EF4444" Kind="Delete" />
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border
            Grid.Row="2"
            Margin="16,0,16,16"
            Padding="12,10"
            Background="#1E1E1E"
            CornerRadius="6"
            Visibility="{Binding IsLocalAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12" Foreground="#F59E0B" Text="应急编辑" />
                <TextBox Width="120" Margin="0,0,6,0" materialDesign:HintAssist.Hint="参数名" FontSize="12" Text="{Binding EditKey, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Width="80" Margin="0,0,6,0" materialDesign:HintAssist.Hint="下限" FontSize="12" Text="{Binding EditMin, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Width="80" Margin="0,0,6,0" materialDesign:HintAssist.Hint="上限" FontSize="12" Text="{Binding EditMax, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Width="80" Margin="0,0,8,0" materialDesign:HintAssist.Hint="单位" FontSize="12" Text="{Binding EditUnit, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Height="30"
                    Padding="12,0"
                    Background="#0F766E"
                    BorderThickness="0"
                    Command="{Binding SaveLocalParamCommand}"
                    Content="保存"
                    FontSize="12"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>
        </Border>
    </Grid>
</sharedViews:PageActionShell>
