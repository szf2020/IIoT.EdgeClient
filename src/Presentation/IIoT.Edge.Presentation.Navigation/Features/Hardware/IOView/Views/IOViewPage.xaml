<UserControl
    x:Class="IIoT.Edge.Presentation.Navigation.Features.Hardware.IOView.IOViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">
    <sharedViews:PageActionShell>

    <sharedViews:PageActionShell.HeaderContent>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="0,0,16,0"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Medium"
                Foreground="#E4E4E7"
                Text="IO 交互" />

            <ComboBox
                Grid.Column="1"
                materialDesign:HintAssist.Hint="选择设备"
                DisplayMemberPath="DeviceName"
                FontSize="13"
                Foreground="#E4E4E7"
                ItemsSource="{Binding Devices}"
                SelectedItem="{Binding SelectedDevice}"
                Style="{StaticResource MaterialDesignOutlinedComboBox}" />

            <StackPanel
                Grid.Column="2"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Ellipse Width="10" Height="10">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#EF4444" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#22C55E" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Margin="6,0,0,0" FontSize="13" Foreground="#A1A1AA" Text="{Binding StatusText}" />
            </StackPanel>
        </Grid>
    </sharedViews:PageActionShell.HeaderContent>

    <sharedViews:PageActionShell.ActionContent>
        <Button
            Height="32"
            Padding="16,0"
            Background="#0F766E"
            BorderThickness="0"
            Command="{Binding WriteCommand}"
            Style="{StaticResource MaterialDesignRaisedButton}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center" Foreground="White" Kind="Send" />
                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="White" Text="写入 PLC" />
            </StackPanel>
        </Button>
    </sharedViews:PageActionShell.ActionContent>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="16,0,0,16" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,0" Background="#27272A" CornerRadius="8,8,0,0">
                    <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="Medium" Foreground="#22C55E" Text="读取信号（PLC 到上位机）" />
                </Border>

                <DataGrid
                    Grid.Row="1"
                    AlternatingRowBackground="#232326"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    Foreground="#E4E4E7"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#333"
                    IsReadOnly="True"
                    ItemsSource="{Binding ReadSignals}"
                    RowBackground="#1E1E1E">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Binding="{Binding Label}" Header="信号名称" />
                        <DataGridTextColumn Width="100" Binding="{Binding PlcAddress}" Header="地址" />
                        <DataGridTextColumn Width="70" Binding="{Binding DataType}" Header="类型" />
                        <DataGridTextColumn Width="80" Binding="{Binding Value}" Header="当前值">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#22C55E" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="2" Margin="0,0,16,16" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,0" Background="#27272A" CornerRadius="8,8,0,0">
                    <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="Medium" Foreground="#F59E0B" Text="写入信号（上位机 到 PLC）" />
                </Border>

                <DataGrid
                    Grid.Row="1"
                    AlternatingRowBackground="#232326"
                    AutoGenerateColumns="False"
                    Background="Transparent"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    Foreground="#E4E4E7"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    HorizontalGridLinesBrush="#333"
                    ItemsSource="{Binding WriteSignals}"
                    RowBackground="#1E1E1E">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Binding="{Binding Label}" Header="信号名称" IsReadOnly="True" />
                        <DataGridTextColumn Width="100" Binding="{Binding PlcAddress}" Header="地址" IsReadOnly="True" />
                        <DataGridTextColumn Width="70" Binding="{Binding DataType}" Header="类型" IsReadOnly="True" />
                        <DataGridTextColumn Width="80" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="写入值">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#F59E0B" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
    </sharedViews:PageActionShell>
</UserControl>
