<UserControl
    x:Class="IIoT.Edge.Presentation.Navigation.Features.Hardware.HardwareConfigView.IoMappingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <sharedViews:PageActionShell>

    <sharedViews:PageActionShell.HeaderContent>
        <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="Medium" Foreground="#E4E4E7" Text="IO 映射" />
    </sharedViews:PageActionShell.HeaderContent>

    <sharedViews:PageActionShell.ActionContent>
        <StackPanel Orientation="Horizontal">
            <Button
                Height="30"
                Margin="0,0,8,0"
                Padding="12,0"
                Command="{Binding ApplyModuleTemplateCommand}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Kind="WrenchCog" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Text="应用模板" />
                </StackPanel>
            </Button>
            <Button
                Height="30"
                Margin="0,0,8,0"
                Padding="12,0"
                Command="{Binding AddIoMappingCommand}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Kind="Plus" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Text="新增" />
                </StackPanel>
            </Button>
            <Button
                Height="30"
                Padding="12,0"
                Command="{Binding DeleteIoMappingCommand}"
                CommandParameter="{Binding SelectedItem, ElementName=IoGrid}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Kind="Delete" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Text="删除" />
                </StackPanel>
            </Button>
        </StackPanel>
    </sharedViews:PageActionShell.ActionContent>

    <Grid Margin="16,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Margin="0,0,12,0"
            BorderBrush="#27272A"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    FontSize="12"
                    Foreground="#71717A"
                    Text="网络设备" />
                <ListBox
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding NetworkDevices}"
                    SelectedItem="{Binding SelectedNetworkDevice}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                Padding="4,6"
                                FontSize="13"
                                Foreground="#E4E4E7"
                                Text="{Binding DeviceName}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,12"
                Padding="12"
                Background="#101114"
                BorderBrush="#27272A"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding HasModuleTemplateSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#E4E4E7"
                        Text="模块协议摘要" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="12"
                        Foreground="#A1A1AA"
                        Text="{Binding ModuleTemplateSummary}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <DataGrid
                x:Name="IoGrid"
                Grid.Row="1"
                AlternatingRowBackground="#0F0F0F"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                FontSize="13"
                Foreground="#E4E4E7"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                IsReadOnly="{Binding CanEdit, Converter={StaticResource InverseBooleanConverter}}"
                ItemsSource="{Binding IoMappings}"
                RowBackground="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="120" Binding="{Binding Label}" Header="标签" />
                    <DataGridTextColumn Width="100" Binding="{Binding PlcAddress}" Header="PLC地址" />
                    <DataGridTextColumn Width="70" Binding="{Binding AddressCount}" Header="数量" />
                    <DataGridTemplateColumn Width="90" Header="数据类型">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Padding="4,0" VerticalAlignment="Center" Foreground="#E4E4E7" Text="{Binding DataType}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding DataType, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.Items>
                                        <sys:String>Bool</sys:String>
                                        <sys:String>Int16</sys:String>
                                        <sys:String>Int32</sys:String>
                                        <sys:String>Float</sys:String>
                                    </ComboBox.Items>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="80" Header="方向">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Padding="4,0" VerticalAlignment="Center" Foreground="#E4E4E7" Text="{Binding Direction}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedItem="{Binding Direction, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.Items>
                                        <sys:String>Read</sys:String>
                                        <sys:String>Write</sys:String>
                                    </ComboBox.Items>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="60" Binding="{Binding SortOrder}" Header="排序" />
                    <DataGridTextColumn Width="*" Binding="{Binding Remark}" Header="备注" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel
                Grid.Row="2"
                Margin="0,8,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#71717A">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="共 {0} 条">
                            <Binding Path="IoTotalCount" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <Button Width="28" Height="28" Padding="0" Command="{Binding IoPrevPageCommand}" Style="{StaticResource MaterialDesignOutlinedButton}">
                    <materialDesign:PackIcon Width="16" Height="16" Kind="ChevronLeft" />
                </Button>
                <TextBlock Margin="8,0" VerticalAlignment="Center" FontSize="12" Foreground="#E4E4E7">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} / {1}">
                            <Binding Path="IoPageIndex" />
                            <Binding Path="IoTotalCount" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <Button Width="28" Height="28" Padding="0" Command="{Binding IoNextPageCommand}" Style="{StaticResource MaterialDesignOutlinedButton}">
                    <materialDesign:PackIcon Width="16" Height="16" Kind="ChevronRight" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
    </sharedViews:PageActionShell>
</UserControl>
