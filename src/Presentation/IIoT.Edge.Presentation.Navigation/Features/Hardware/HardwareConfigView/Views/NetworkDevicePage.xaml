<UserControl
    x:Class="IIoT.Edge.Presentation.Navigation.Features.Hardware.HardwareConfigView.NetworkDevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">
    <sharedViews:PageActionShell>
    <sharedViews:PageActionShell.HeaderContent>
        <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="Medium" Foreground="#E4E4E7" Text="网络设备" />
    </sharedViews:PageActionShell.HeaderContent>

    <sharedViews:PageActionShell.ActionContent>
        <StackPanel Orientation="Horizontal">
            <Button
                Height="30"
                Margin="0,0,8,0"
                Padding="12,0"
                Command="{Binding AddNetworkDeviceCommand}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Kind="Plus" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Text="新增" />
                </StackPanel>
            </Button>
            <Button
                Height="30"
                Padding="12,0"
                Command="{Binding DeleteNetworkDeviceCommand}"
                CommandParameter="{Binding SelectedItem, ElementName=NetworkGrid}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Kind="Delete" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Text="删除" />
                </StackPanel>
            </Button>
        </StackPanel>
    </sharedViews:PageActionShell.ActionContent>

    <Grid Margin="16,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DataGrid
            x:Name="NetworkGrid"
            Grid.Row="0"
            AlternatingRowBackground="#0F0F0F"
            AutoGenerateColumns="False"
            Background="Transparent"
            BorderThickness="0"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            FontSize="13"
            Foreground="#E4E4E7"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            IsReadOnly="{Binding CanEdit, Converter={StaticResource InverseBooleanConverter}}"
            ItemsSource="{Binding NetworkDevices}"
            RowBackground="Transparent">
            <DataGrid.Columns>
                <DataGridTextColumn Width="120" Binding="{Binding DeviceName}" Header="设备名称" />
                <DataGridTemplateColumn Width="110" Header="设备类型">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Padding="4,0" VerticalAlignment="Center" Foreground="#E4E4E7" Text="{Binding DeviceType}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DeviceTypes}" SelectedItem="{Binding DeviceType, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="110" Header="设备型号">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Padding="4,0" VerticalAlignment="Center" Foreground="#E4E4E7" Text="{Binding DeviceModel}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding DeviceModel, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="120" Binding="{Binding ModuleId}" Header="ModuleId" />
                <DataGridTextColumn Width="130" Binding="{Binding IpAddress}" Header="IP地址" />
                <DataGridTextColumn Width="80" Binding="{Binding Port1}" Header="端口1" />
                <DataGridTextColumn Width="80" Binding="{Binding Port2}" Header="端口2" />
                <DataGridTextColumn Width="100" Binding="{Binding SendCmd1}" Header="指令1" />
                <DataGridTextColumn Width="100" Binding="{Binding SendCmd2}" Header="指令2" />
                <DataGridTextColumn Width="90" Binding="{Binding ConnectTimeout}" Header="超时(ms)" />
                <DataGridCheckBoxColumn Width="60" Binding="{Binding IsEnabled}" Header="启用" />
                <DataGridTextColumn Width="*" Binding="{Binding Remark}" Header="备注" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
    </sharedViews:PageActionShell>
</UserControl>
