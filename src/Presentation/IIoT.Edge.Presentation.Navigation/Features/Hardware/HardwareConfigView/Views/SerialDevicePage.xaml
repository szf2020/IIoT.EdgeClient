<UserControl
    x:Class="IIoT.Edge.Presentation.Navigation.Features.Hardware.HardwareConfigView.SerialDevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">
    <sharedViews:PageActionShell>
    <sharedViews:PageActionShell.HeaderContent>
        <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="Medium" Foreground="#E4E4E7" Text="串口设备" />
    </sharedViews:PageActionShell.HeaderContent>

    <sharedViews:PageActionShell.ActionContent>
        <StackPanel Orientation="Horizontal">
            <Button
                Height="30"
                Margin="0,0,8,0"
                Padding="12,0"
                Command="{Binding AddSerialDeviceCommand}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Kind="Plus" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Text="新增" />
                </StackPanel>
            </Button>
            <Button
                Height="30"
                Padding="12,0"
                Command="{Binding DeleteSerialDeviceCommand}"
                CommandParameter="{Binding SelectedItem, ElementName=SerialGrid}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Kind="Delete" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12" Text="删除" />
                </StackPanel>
            </Button>
        </StackPanel>
    </sharedViews:PageActionShell.ActionContent>

    <Grid Margin="16,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DataGrid
            x:Name="SerialGrid"
            Grid.Row="0"
            AlternatingRowBackground="#0F0F0F"
            AutoGenerateColumns="False"
            Background="Transparent"
            BorderThickness="0"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            FontSize="13"
            Foreground="#E4E4E7"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            IsReadOnly="{Binding CanEdit, Converter={StaticResource InverseBooleanConverter}}"
            ItemsSource="{Binding SerialDevices}"
            RowBackground="Transparent">
            <DataGrid.Columns>
                <DataGridTextColumn Width="120" Binding="{Binding DeviceName}" Header="设备名称" />
                <DataGridTextColumn Width="100" Binding="{Binding DeviceType}" Header="设备类型" />
                <DataGridTextColumn Width="80" Binding="{Binding PortName}" Header="串口号" />
                <DataGridTextColumn Width="80" Binding="{Binding BaudRate}" Header="波特率" />
                <DataGridTextColumn Width="70" Binding="{Binding DataBits}" Header="数据位" />
                <DataGridTemplateColumn Width="80" Header="停止位">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Padding="4,0" VerticalAlignment="Center" Foreground="#E4E4E7" Text="{Binding StopBits}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding StopBits, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.Items>
                                    <sys:String>One</sys:String>
                                    <sys:String>OnePointFive</sys:String>
                                    <sys:String>Two</sys:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="80" Header="校验位">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Padding="4,0" VerticalAlignment="Center" Foreground="#E4E4E7" Text="{Binding Parity}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding Parity, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.Items>
                                    <sys:String>None</sys:String>
                                    <sys:String>Odd</sys:String>
                                    <sys:String>Even</sys:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="100" Binding="{Binding SendCmd1}" Header="指令1" />
                <DataGridTextColumn Width="100" Binding="{Binding SendCmd2}" Header="指令2" />
                <DataGridCheckBoxColumn Width="60" Binding="{Binding IsEnabled}" Header="启用" />
                <DataGridTextColumn Width="*" Binding="{Binding Remark}" Header="备注" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
    </sharedViews:PageActionShell>
</UserControl>
