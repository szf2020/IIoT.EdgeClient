<sharedViews:PageActionShell
    x:Class="IIoT.Edge.Presentation.Panels.Features.SysLog.LogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sharedViews="clr-namespace:IIoT.Edge.UI.Shared.Views;assembly=IIoT.Edge.UI.Shared"
    Background="Transparent">

    <sharedViews:PageActionShell.HeaderContent>
        <TextBlock
            FontSize="16"
            FontWeight="Medium"
            Foreground="#E4E4E7"
            Text="系统日志" />
    </sharedViews:PageActionShell.HeaderContent>

    <sharedViews:PageActionShell.ActionContent>
        <Button Height="22" Padding="4,0" Command="{Binding ClearCommand}" Style="{StaticResource MaterialDesignFlatButton}" ToolTip="清空日志">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Width="12" Height="12" VerticalAlignment="Center" Foreground="#52525B" Kind="DeleteOutline" />
                <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#52525B" Text="清空" />
            </StackPanel>
        </Button>
    </sharedViews:PageActionShell.ActionContent>

    <Grid Margin="8">
        <ListView Background="Transparent" BorderThickness="0" ItemsSource="{Binding Entries}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="8,2" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListViewItem"><ContentPresenter /></ControlTemplate></Setter.Value></Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="8,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="130" /><ColumnDefinition Width="44" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="11" Foreground="#52525B" Text="{Binding Time, StringFormat='{}{0:MM-dd HH:mm:ss.fff}'}" />
                        <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Text="{Binding Level}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#A1A1AA" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="ERROR"><Setter Property="Foreground" Value="#F44336" /></DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="FATAL"><Setter Property="Foreground" Value="#FF1744" /></DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="WARN"><Setter Property="Foreground" Value="#FFC107" /></DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="INFO"><Setter Property="Foreground" Value="#4CAF50" /></DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="DEBUG"><Setter Property="Foreground" Value="#607D8B" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="2" FontSize="11" Foreground="#A1A1AA" Text="{Binding Message}" TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</sharedViews:PageActionShell>
