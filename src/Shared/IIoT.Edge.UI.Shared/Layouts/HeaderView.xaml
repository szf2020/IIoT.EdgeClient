<UserControl
    x:Class="IIoT.Edge.UI.Shared.Layouts.HeaderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Height="60">
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Column="0"
            Margin="20,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Image Height="28" Source="pack://application:,,,/IIoT.Edge.UI.Shared;component/Assets/images/logo.png" />
            <TextBlock
                Margin="15,0,0,0"
                VerticalAlignment="Center"
                Foreground="#333333">
                <Run
                    FontSize="18"
                    FontWeight="Bold"
                    Text="IIoT Edge Controller" />
                <Run
                    FontSize="12"
                    Foreground="#999999"
                    Text=" v2.0" />
            </TextBlock>
        </StackPanel>

        <Grid Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <materialDesign:Chip
                Grid.Column="1"
                Margin="0,0,15,0"
                Content="Admin"
                FontFamily="{StaticResource IconFont}"
                Icon="&#xe641;"
                Style="{StaticResource MaterialDesignOutlineChip}" />

            <UniformGrid
                Grid.Column="2"
                VerticalAlignment="Top"
                Columns="3">
                <Button
                    x:Name="btn_MiniSize"
                    Content="─"
                    Style="{StaticResource MaterialDesignFlatButton}" />
                <Button
                    x:Name="btn_MaxSize"
                    Content="☐"
                    Style="{StaticResource MaterialDesignFlatButton}" />
                <Button
                    x:Name="btn_Close"
                    Click="btn_Close_Click"
                    Content="✕"
                    Foreground="Crimson"
                    Style="{StaticResource MaterialDesignFlatButton}" />
            </UniformGrid>
        </Grid>
        <Border
            Grid.ColumnSpan="3"
            Height="1"
            VerticalAlignment="Bottom"
            Background="#E5E5E5" />
    </Grid>
</UserControl>