<UserControl x:Class="IIoT.Edge.UI.Shared.Widgets.SystemHeader.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent"
             Height="45">

    <Border Background="Transparent"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0,0,0">
                <Image Height="22" Source="pack://application:,,,/IIoT.Edge.UI.Shared;component/Assets/images/logo.png" VerticalAlignment="Center" />

                <TextBlock Text="{Binding SystemTitle}"
                           Margin="15,0,0,0" VerticalAlignment="Center"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesignBody}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <materialDesign:Chip Content="Admin"
                                     Icon="&#xe641;"
                                     FontFamily="pack://application:,,,/IIoT.Edge.UI.Shared;component/Assets/fonts/#iconfont"
                                     Margin="0,0,20,0"
                                     Foreground="{DynamicResource MaterialDesignBody}"
                                     Background="Transparent"
                                     VerticalAlignment="Center" />

                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Command="{Binding WindowControlCommand}" CommandParameter="Min" Style="{StaticResource WindowControlBtnStyle}">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14" Foreground="{DynamicResource MaterialDesignBody}" />
                    </Button>
                    <Button Command="{Binding WindowControlCommand}" CommandParameter="Max" Style="{StaticResource WindowControlBtnStyle}">
                        <materialDesign:PackIcon Kind="WindowMaximize" Width="14" Height="14" Foreground="{DynamicResource MaterialDesignBody}" />
                    </Button>
                    <Button Command="{Binding WindowControlCommand}" CommandParameter="Close" Style="{StaticResource WindowCloseBtnStyle}">
                        <materialDesign:PackIcon Kind="WindowClose" Width="14" Height="14" Foreground="{DynamicResource MaterialDesignBody}" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>