<UserControl
    x:Class="IIoT.Edge.UI.Shared.Widgets.Login.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Width="380"
    Background="Transparent">

    <Border
        Padding="32,28"
        Background="#1E1E1E"
        CornerRadius="12">
        <StackPanel>

            <!--  标题区  -->
            <StackPanel Margin="0,0,0,24" Orientation="Horizontal">
                <materialDesign:PackIcon
                    Width="24"
                    Height="24"
                    VerticalAlignment="Center"
                    Foreground="#5EEAD4"
                    Kind="ShieldLockOutline" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="#E4E4E7"
                    Text="{Binding ModeTitle}" />
            </StackPanel>

            <!--  工号输入（仅云端模式显示）  -->
            <TextBox
                Margin="0,0,0,16"
                materialDesign:HintAssist.FloatingScale="0.8"
                materialDesign:HintAssist.Hint="工号"
                CaretBrush="#5EEAD4"
                Foreground="#E4E4E7"
                Text="{Binding EmployeeNo, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}" TargetType="TextBox">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLocalMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!--  密码输入  -->
            <PasswordBox
                x:Name="PasswordBox"
                Margin="0,0,0,8"
                materialDesign:HintAssist.FloatingScale="0.8"
                materialDesign:HintAssist.Hint="密码"
                CaretBrush="#5EEAD4"
                Foreground="#E4E4E7"
                Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" />

            <!--  错误提示  -->
            <TextBlock
                Margin="0,0,0,16"
                FontSize="12"
                Foreground="#F87171"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!--  登录按钮  -->
            <Button
                Height="44"
                Margin="0,0,0,12"
                materialDesign:ButtonAssist.CornerRadius="8"
                Background="#0F766E"
                BorderThickness="0"
                Command="{Binding LoginCommand}"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="White">
                <Grid>
                    <!--  正常状态文字  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="登 录">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!--  加载中转圈  -->
                    <ProgressBar
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="White"
                        IsIndeterminate="True"
                        Style="{StaticResource MaterialDesignCircularProgressBar}">
                        <ProgressBar.Visibility>
                            <Binding Path="IsBusy">
                                <Binding.Converter>
                                    <BooleanToVisibilityConverter />
                                </Binding.Converter>
                            </Binding>
                        </ProgressBar.Visibility>
                    </ProgressBar>
                </Grid>
            </Button>

            <!--  切换模式  -->
            <Button
                HorizontalAlignment="Center"
                Command="{Binding SwitchModeCommand}"
                FontSize="12"
                Foreground="#A1A1AA"
                Style="{StaticResource MaterialDesignFlatButton}">
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="切换到本地紧急管理员" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLocalMode}" Value="True">
                                    <Setter Property="Text" Value="切换到云端账号登录" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

        </StackPanel>
    </Border>
</UserControl>