<UserControl x:Class="IIoT.Edge.UI.Shared.Widgets.SysMenu.SysMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             x:Name="Root"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0"
                 ItemsSource="{Binding DataContext.MenuItems,
                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Background="Transparent"
                 BorderThickness="0"
                 SelectionMode="Single">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="6"
                            Margin="4,2"
                            Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="#27272A" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Button Click="MenuItem_Click"
                                Tag="{Binding WidgetId}"
                                IsEnabled="{Binding IsAccessible}"
                                Height="48"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="{Binding Icon}"
                                                         Width="18" Height="18"
                                                         VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Foreground" Value="#A1A1AA" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="#5EEAD4" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsAccessible}" Value="False">
                                                    <Setter Property="Foreground" Value="#3F3F46" />
                                                    <Setter Property="Opacity" Value="0.4" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>

                                <TextBlock Text="{Binding Title}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#A1A1AA" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="#5EEAD4" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsAccessible}" Value="False">
                                                    <Setter Property="Foreground" Value="#3F3F46" />
                                                    <Setter Property="Opacity" Value="0.4" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0"
                Padding="8,8">
            <Button Click="LoginBtn_Click"
                    Height="48"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,0"
                    Margin="4,0"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="LoginVariant"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"
                                             Foreground="#A1A1AA" />
                    <TextBlock
                        Text="{Binding DataContext.LoginButtonText,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#A1A1AA" />
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</UserControl>