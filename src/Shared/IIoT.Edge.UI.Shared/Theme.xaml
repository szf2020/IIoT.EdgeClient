<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalon="https://github.com/Dirkster99/AvalonDock"
    xmlns:converters="clr-namespace:IIoT.Edge.UI.Shared.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ResourceDictionary.MergedDictionaries>
        <materialDesign:BundledTheme
            BaseTheme="Dark"
            PrimaryColor="BlueGrey"
            SecondaryColor="Teal" />
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
        <ResourceDictionary Source="/AvalonDock.Themes.VS2013;component/DarkBrushs.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--  工业风颜色变量  -->
    <SolidColorBrush x:Key="Ind.Bg.Main" Color="#121212" />
    <SolidColorBrush x:Key="Ind.Bg.Panel" Color="#1E1E1E" />
    <SolidColorBrush x:Key="Ind.Border.Muted" Color="#333333" />
    <SolidColorBrush x:Key="Ind.Text.Primary" Color="#E4E4E7" />
    <SolidColorBrush x:Key="Ind.Text.Muted" Color="#A1A1AA" />

    <!--  窗口控制按钮样式  -->
    <Style
        x:Key="WindowControlBtnStyle"
        BasedOn="{StaticResource MaterialDesignFlatButton}"
        TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Ind.Text.Muted}" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0" />
    </Style>

    <!--  关闭按钮样式  -->
    <Style
        x:Key="WindowCloseBtnStyle"
        BasedOn="{StaticResource WindowControlBtnStyle}"
        TargetType="Button">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E81123" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  导航菜单按钮样式  -->
    <Style x:Key="NavMenuBtnStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#A1A1AA" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Margin" Value="4,2" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="border"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#27272A" />
                            <Setter Property="Foreground" Value="#E4E4E7" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#3F3F46" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  AvalonDock 深色覆盖样式  -->
    <Style TargetType="{x:Type avalon:DockingManager}">
        <Setter Property="Background" Value="#121212" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="{x:Type avalon:LayoutDocumentPaneControl}">
        <Setter Property="Background" Value="#121212" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="{x:Type avalon:LayoutDocumentControl}">
        <Setter Property="Background" Value="#1E1E1E" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="{x:Type avalon:LayoutAnchorablePaneControl}">
        <Setter Property="Background" Value="#121212" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
</ResourceDictionary>
