<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Ind.Bg.Main" Color="#18181B" />
    <SolidColorBrush x:Key="Ind.Bg.Panel" Color="#27272A" />
    <SolidColorBrush x:Key="Ind.Color.Primary" Color="#0EA5E9" />
    <SolidColorBrush x:Key="Ind.Color.Success" Color="#10B981" />
    <SolidColorBrush x:Key="Ind.Color.Alert" Color="#EF4444" />

    <SolidColorBrush x:Key="Ind.Text.Primary" Color="#F4F4F5" />
    <SolidColorBrush x:Key="Ind.Text.Secondary" Color="#A1A1AA" />

    <SolidColorBrush x:Key="Ind.Border.Muted" Color="#3F3F46" />

    <Style x:Key="WidgetContainerStyle" TargetType="ContentPresenter">
        <Setter Property="Grid.Row" Value="{Binding LayoutRow}" />
        <Setter Property="Grid.Column" Value="{Binding LayoutColumn}" />
        <Setter Property="Grid.RowSpan" Value="{Binding RowSpan}" />
        <Setter Property="Grid.ColumnSpan" Value="{Binding ColumnSpan}" />

        <Setter Property="Margin" Value="4" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentPresenter">
                    <Border
                        Background="{StaticResource Ind.Bg.Panel}"
                        BorderBrush="{StaticResource Ind.Border.Muted}"
                        BorderThickness="1"
                        CornerRadius="2"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border
                                Grid.Row="0"
                                Padding="8,4"
                                BorderBrush="{StaticResource Ind.Border.Muted}"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource Ind.Text.Secondary}"
                                    Text="{Binding WidgetName}" />
                            </Border>

                            <ContentPresenter Grid.Row="1" Margin="8" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>